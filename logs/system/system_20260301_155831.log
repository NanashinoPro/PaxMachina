  ],
  "update_hidden_plans": "次回以降のターンに引き継ぐべき非公開の計画・長期戦略のメモ（目標達成や状況の重大な変化があれば動的に再定義すること）",
  "domestic_policy": {
    "invest_economy": 0.0から1.0の数値,
