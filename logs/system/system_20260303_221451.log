      "cancel_trade": trueかfalseのブール値,
      "impose_sanctions": trueかfalseのブール値,
      "lift_sanctions": trueかfalseのブール値,
      "propose_summit": trueかfalseのブール値,
      "summit_topic": "首脳会談の議題（propose_summitがtrueの場合記述）",
      "accept_summit": trueかfalseのブール値,
