    "invest_military": 0.0から1.0の数値,
    "invest_welfare": 0.0から1.0の数値
  },
  "diplomatic_policies": [
    {
      "target_country": "他国の名前",
      "message": "その国へ発信する公開メッセージ",
      "propose_alliance": trueかfalseのブール値,
